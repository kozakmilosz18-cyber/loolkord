local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera

local Player = Players.LocalPlayer
local Mouse = Player:GetMouse()

-- Configuration
local CONFIG = {
    FOVRadius = 90,
    MaxDistance = 200,
    ActivateKey = Enum.KeyCode.C,
    LockStrength = 0.3,
    NormalColor = Color3.fromRGB(255, 255, 255),
    NormalGlowColor = Color3.fromRGB(200, 200, 255),
    ActiveColor = Color3.fromRGB(255, 200, 100),
    TargetColor = Color3.fromRGB(180, 0, 255),
    TargetGlowColor = Color3.fromRGB(220, 100, 255),
    DashLength = 6,
    GapLength = 12,
    RotationSpeed = 180,
}

-- Create FOV GUI
local function CreateFOVGUI()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "SilentAimFOV"
    screenGui.ResetOnSpawn = false
    screenGui.IgnoreGuiInset = true
    screenGui.Parent = Player:WaitForChild("PlayerGui")
    
    local fovFrame = Instance.new("Frame")
    fovFrame.Name = "FOVFrame"
    fovFrame.Size = UDim2.new(0, CONFIG.FOVRadius * 2, 0, CONFIG.FOVRadius * 2)
    fovFrame.Position = UDim2.new(0.5, -CONFIG.FOVRadius, 0.5, -CONFIG.FOVRadius)
    fovFrame.BackgroundTransparency = 1
    fovFrame.ClipsDescendants = true
    fovFrame.Parent = screenGui
    
    local circleContainer = Instance.new("Frame")
    circleContainer.Name = "CircleContainer"
    circleContainer.Size = UDim2.new(1, 0, 1, 0)
    circleContainer.Position = UDim2.new(0, 0, 0, 0)
    circleContainer.BackgroundTransparency = 1
    circleContainer.Parent = fovFrame
    
    local dashParts = {}
    local numDashes = math.floor((2 * math.pi * CONFIG.FOVRadius) / (CONFIG.DashLength + CONFIG.GapLength))
    local angleStep = (2 * math.pi) / numDashes
    
    for i = 1, numDashes do
        local angle = i * angleStep
        local x = CONFIG.FOVRadius * math.cos(angle)
        local y = CONFIG.FOVRadius * math.sin(angle)
        
        local dash = Instance.new("Frame")
        dash.Name = "Dash_" .. i
        dash.Size = UDim2.new(0, CONFIG.DashLength, 0, 1.0)
        dash.Position = UDim2.new(0.5, x - CONFIG.DashLength/2, 0.5, y - 0.5)
        dash.BackgroundColor3 = CONFIG.NormalColor
        dash.BackgroundTransparency = 0.1
        dash.BorderSizePixel = 0
        dash.Rotation = math.deg(angle)
        dash.Parent = circleContainer
        
        local glow = Instance.new("Frame")
        glow.Name = "Glow"
        glow.Size = UDim2.new(1, 4, 1, 4)
        glow.Position = UDim2.new(0.5, -2, 0.5, -2)
        glow.BackgroundColor3 = CONFIG.NormalGlowColor
        glow.BackgroundTransparency = 0.8
        glow.BorderSizePixel = 0
        glow.Parent = dash
        
        table.insert(dashParts, {
            Frame = dash,
            Glow = glow,
            Angle = angle,
        })
    end
    
    local statusLabel = Instance.new("TextLabel")
    statusLabel.Name = "StatusLabel"
    statusLabel.Size = UDim2.new(0, 200, 0, 25)
    statusLabel.Position = UDim2.new(0.5, -100, 1.2, 0)
    statusLabel.BackgroundTransparency = 1
    statusLabel.Text = "⬜ READY"
    statusLabel.TextColor3 = CONFIG.NormalColor
    statusLabel.TextSize = 14
    statusLabel.Font = Enum.Font.SourceSansBold
    statusLabel.Parent = fovFrame
    
    return {
        ScreenGui = screenGui,
        FOVFrame = fovFrame,
        DashParts = dashParts,
        StatusLabel = statusLabel,
        Rotation = 0,
    }
end

-- Get targets
local function GetTargets()
    local targets = {}
    local cameraPos = Camera.CFrame.Position
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= Player and player.Character then
            local humanoid = player.Character:FindFirstChild("Humanoid")
            local head = player.Character:FindFirstChild("Head")
            
            if humanoid and head and humanoid.Health > 0 then
                -- Get screen position of head
                local headPos, onScreen = Camera:WorldToScreenPoint(head.Position)
                if onScreen then
                    local distance = (head.Position - cameraPos).Magnitude
                    if distance <= CONFIG.MaxDistance then
                        table.insert(targets, {
                            Player = player,
                            Head = head,
                            HeadScreenPos = Vector2.new(headPos.X, headPos.Y),
                            Distance = distance,
                            HeadPosition = head.Position,
                        })
                    end
                end
            end
        end
    end
    
    return targets
end

-- Get closest target in FOV
local function GetClosestTarget(targets)
    local best = nil
    local bestDist = CONFIG.FOVRadius + 1
    
    -- Get screen center
    local viewportSize = Camera.ViewportSize
    local center = Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)
    
    for _, target in pairs(targets) do
        local dist = (target.HeadScreenPos - center).Magnitude
        if dist <= CONFIG.FOVRadius and dist < bestDist then
            bestDist = dist
            best = target
        end
    end
    
    return best
end

-- Update FOV colors
local function UpdateFOVColors(color, glowColor, statusText)
    for _, data in pairs(fovData.DashParts) do
        data.Frame.BackgroundColor3 = color
        data.Glow.BackgroundColor3 = glowColor or color
    end
    fovData.StatusLabel.Text = statusText
    fovData.StatusLabel.TextColor3 = color
end

-- Initialize
local fovData = CreateFOVGUI()
local isActive = false
local currentTarget = nil

-- Rotation animation
RunService.Heartbeat:Connect(function(deltaTime)
    fovData.Rotation = (fovData.Rotation + CONFIG.RotationSpeed * deltaTime) % 360
    local angleOffset = math.rad(fovData.Rotation)
    
    for _, data in pairs(fovData.DashParts) do
        local angle = data.Angle + angleOffset
        local x = CONFIG.FOVRadius * math.cos(angle)
        local y = CONFIG.FOVRadius * math.sin(angle)
        data.Frame.Position = UDim2.new(0.5, x - CONFIG.DashLength/2, 0.5, y - 0.5)
        data.Frame.Rotation = math.deg(angle)
    end
end)

-- Toggle with X key
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.X then
        isActive = not isActive
        
        if isActive then
            UpdateFOVColors(CONFIG.ActiveColor, CONFIG.ActiveColor, "🟠 AIMING")
            print("✅ AIMLOCK ACTIVATED - Press X to toggle")
        else
            UpdateFOVColors(CONFIG.NormalColor, CONFIG.NormalGlowColor, "⬜ READY")
            currentTarget = nil
            print("✅ AIMLOCK DEACTIVATED")
        end
    end
end)

-- Main loop - SIMPLE CAMLOCK
RunService.RenderStepped:Connect(function()
    if not isActive then
        if fovData.StatusLabel.Text ~= "⬜ READY" then
            UpdateFOVColors(CONFIG.NormalColor, CONFIG.NormalGlowColor, "⬜ READY")
        end
        return
    end
    
    if not Player.Character then return end
    local humanoid = Player.Character:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return end
    
    -- Get targets
    local targets = GetTargets()
    
    if #targets == 0 then
        UpdateFOVColors(CONFIG.ActiveColor, CONFIG.ActiveColor, "🟠 NO PLAYERS")
        currentTarget = nil
        return
    end
    
    -- Find closest target in FOV
    local target = GetClosestTarget(targets)
    
    if target then
        -- We have a target!
        currentTarget = target
        
        -- Get head position
        local headPos = target.HeadPosition
        local camPos = Camera.CFrame.Position
        
        -- Calculate direction
        local direction = (headPos - camPos).Unit
        
        -- Create target CFrame
        local targetCFrame = CFrame.lookAt(camPos, camPos + direction)
        
        -- Apply smooth lock
        Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, CONFIG.LockStrength)
        
        -- Update UI
        UpdateFOVColors(
            CONFIG.TargetColor,
            CONFIG.TargetGlowColor,
            "💜 " .. target.Player.Name .. " (" .. math.floor(target.Distance) .. "s)"
        )
    else
        -- No target in FOV
        UpdateFOVColors(CONFIG.ActiveColor, CONFIG.ActiveColor, "🟠 NO TARGET")
        currentTarget = nil
    end
end)

-- Cleanup
Player.CharacterAdded:Connect(function()
    wait(0.5)
    if fovData.FOVFrame then
        fovData.FOVFrame.Visible = true
    end
end)

