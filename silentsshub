--[[
    Silent Aim System - iOS Style FOV HUD
    - F3 to increase FOV by 10
    - F2 to decrease FOV by 10
    - Clean iOS/macOS style HUD
    - Purple FOV circle matching text colors
    - Stretched horizontal design
    - Stays open while adjusting FOV
    - Closes after 5s of inactivity
    - Press X to toggle aimlock
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera
local TweenService = game:GetService("TweenService")

local Player = Players.LocalPlayer
local Mouse = Player:GetMouse()

-- Configuration
local CONFIG = {
    FOVRadius = 90,
    MinFOV = 20,
    MaxFOV = 200,
    MaxDistance = 200,
    ActivateKey = Enum.KeyCode.X,
    LockStrength = 0.15,
    SwitchCooldown = 0.5,
    -- Purple FOV colors matching text
    FOVColor = Color3.fromRGB(200, 140, 230),
    FOVGlowColor = Color3.fromRGB(160, 80, 200),
    DashLength = 6,
    GapLength = 12,
    RotationSpeed = 180,
    HUDAutoHideDelay = 5,
}

